# backend/.env.example
# Copy this file to .env and set your own values.
# DO NOT commit .env — it should be in .gitignore.

# Neon PostgreSQL Connection String
# Get this from https://console.neon.tech/app/projects/old-hat-13256283
# Click "Connect" → copy the PostgreSQL string
DATABASE_URL=postgres://username:password@your-host.neon.tech/dbname?sslmode=require

# Generate a strong random key:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here