{
  "expo": {
    "name": "Field Force",
    "slug": "field-force-contractor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ForceFiledicon.png",
    "scheme": "fieldforcecontractor",
    "userInterfaceStyle": "automatic",
    "updates": {
      "enabled": true,
      "checkAutomatically": "NEVER"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow $(PRODUCT_NAME) to use speech recognition.",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to use the microphone.",
        "NSLocationWhenInUseUsageDescription": "Field Force needs your location to verify job site arrival and departure."
      }
    },
    "android": {
      "package": "com.tr42.fieldforcecontractor",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "splash": {
      "backgroundColor": "#000000",
      "image": "./assets/images/SplashScreenBackGround.png",
      "resizeMode": "contain"

    },
    "plugins": [
      "expo-splash-screen",
      "expo-font",
      "expo-secure-store",
      "expo-location",
      "expo-web-browser"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "bd64f706-e173-412e-9f42-0a50678b58c3"
      }
    }
  }
}
